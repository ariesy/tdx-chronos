# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
*.egg-info/
.pytest_cache/

# 数据卷（不 commit · 8GB+）
data/
data/parquet/
data/fin/
data/index/
data/gp/
data/xdxr/
data/snapshot/
data/meta.db

# 大型 vendor（不 commit · 走 vendoring 工具链）
vendor/*/build/
vendor/*/dist/
*.whl
*.tar.gz

# 日志（运行时）
logs/*.log
logs/*.json

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# 临时文件
*.tmp
*.bak
.cache/

# 凭据
.env
.env.local
secrets.yaml
config/local.yaml

# vendor 解出的 __pycache__ 不 commit
vendor/_vendor/**/__pycache__/
vendor/_vendor/**/*.pyc
